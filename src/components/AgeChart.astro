<div id="age-chart-section" class="hidden mt-8 stagger-in stagger-in-2">
  <div class="card p-4 sm:p-6 md:p-8">
    <h2 class="text-lg sm:text-xl font-semibold tracking-tight text-[var(--text-primary)] mb-1" id="chart-title">Complete Age Chart</h2>
    <p class="text-xs sm:text-sm text-[var(--text-muted)] mb-4 sm:mb-6" id="chart-subtitle"></p>
    <div class="overflow-x-auto -mx-4 sm:-mx-6 md:-mx-0">
      <div class="inline-block min-w-full px-4 sm:px-6 md:px-0">
        <table class="w-full text-sm" id="age-table">
          <thead>
            <tr class="border-b border-[var(--border-default)]">
              <th class="text-left py-2.5 pr-4 text-xs font-mono uppercase tracking-wider text-[var(--text-faint)] font-bold">Dog Age (years)</th>
              <th class="text-left py-2.5 pr-4 text-xs font-mono uppercase tracking-wider text-[var(--text-faint)] font-bold">Human Equivalent</th>
              <th class="text-left py-2.5 text-xs font-mono uppercase tracking-wider text-[var(--text-faint)] font-bold">Life Stage</th>
            </tr>
          </thead>
          <tbody id="chart-body"></tbody>
        </table>
      </div>
    </div>
    <div class="flex flex-col sm:flex-row gap-2 sm:gap-4 mt-4 sm:mt-6 pt-4 border-t border-[var(--border-default)]">
      <button type="button" class="btn-secondary text-sm btn-mobile-full justify-center" id="save-chart-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download as Image
      </button>
      <a href="/dog-age-chart" class="btn-secondary text-sm btn-mobile-full justify-center no-underline" title="Full Dog Age Chart by Breed Size">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        Full Page Chart
      </a>
    </div>
  </div>
</div>
