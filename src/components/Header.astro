---
const primaryLinks = [
  { href: '/', label: 'Calculator' },
  { href: '/dog-age-chart', label: 'Age Chart' },
  { href: '/compare', label: 'Compare' },
];

const toolLinks = [
  { href: '/puppy-weight-calculator', label: 'Puppy Weight 🔮', desc: 'Predict adult size' },
  { href: '/dog-chocolate-toxicity-calculator', label: 'Chocolate Emergency 🍫', desc: 'Toxicity check' },
  { href: '/dog-calorie-calculator', label: 'Calorie Calculator 🥗', desc: 'Food portion needs' },
  { href: '/biological-age-quiz', label: 'Longevity Quiz 🏆', desc: 'Check biological age' },
  { href: '/reverse-calculator', label: 'Reverse Calculator 🔄', desc: 'Human to dog years' },
  { href: '/dog-birthday', label: 'Birthday Countdown 🎂', desc: 'Track next birthday' },
  { href: '/embed-widget', label: 'Free Embed Widget 🔌', desc: 'Add widget to your site' },
];

const aboutLink = { href: '/about', label: 'About' };
---

<site-header>
  <nav id="main-nav" class="sticky top-0 z-50 border-b border-[var(--border-default)] bg-[var(--bg-primary)]/80 backdrop-blur-md transition-all duration-300 scroll-bottom-border" role="navigation" aria-label="Main navigation">
    <div class="container-custom flex items-center justify-between h-16 sm:h-16 nav-inner transition-all duration-300">
      
      <!-- Brand Logo -->
      <a href="/" class="hidden lg:flex items-center gap-2 no-underline shrink-0 transition-transform active:scale-95 duration-200">
        <span class="text-base xl:text-lg font-display font-extrabold tracking-tight text-[var(--text-primary)] flex items-center gap-1.5">🐾 DogBreedAge</span>
      </a>

      <!-- Desktop Menu -->
      <div class="hidden lg:flex items-center gap-1 xl:gap-2 py-1">
        {primaryLinks.map(link => {
          const isActive = Astro.url.pathname === link.href || (link.href !== '/' && Astro.url.pathname === link.href);
          return (
            <a href={link.href} class={`whitespace-nowrap px-4 py-2.5 text-sm font-bold rounded-full transition-all duration-200 no-underline nav-active-indicator ${isActive ? 'active text-[var(--text-primary)] bg-[var(--hover-overlay-strong)]' : 'text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--hover-overlay)]'}`} aria-current={isActive ? 'page' : undefined} title={link.label}>
              {link.label}
            </a>
          );
        })}

        <!-- Dropdown Menu -->
        <div class="relative group">
          <button type="button" class="btn-ghost flex items-center gap-1.5 text-sm font-bold px-4 py-2.5 rounded-full cursor-pointer hover:bg-[var(--hover-overlay)] text-[var(--text-secondary)] hover:text-[var(--text-primary)]" aria-haspopup="true" aria-expanded="false">
            Tools & Health <span class="text-[10px] transition-transform group-hover:rotate-180 duration-200">▼</span>
          </button>
          
          <!-- Dropdown Panel -->
          <div class="absolute top-full left-1/2 -translate-x-1/2 mt-1.5 w-80 bg-[var(--bg-elevated)]/95 backdrop-blur-md border-2 border-[var(--border-default)] shadow-2xl rounded-2xl p-3 grid grid-cols-1 gap-1 transition-all duration-200 opacity-0 invisible scale-95 group-hover:opacity-100 group-hover:visible group-hover:scale-100 translate-y-2 group-hover:translate-y-0 z-50">
            {toolLinks.map(tool => {
              const isActive = Astro.url.pathname === tool.href;
              return (
                <a href={tool.href} class={`flex flex-col p-2.5 rounded-xl transition-all duration-200 no-underline ${isActive ? 'bg-[var(--hover-overlay-strong)]' : 'hover:bg-[var(--hover-overlay)]'}`}>
                  <span class="text-sm font-bold text-[var(--text-primary)]">{tool.label}</span>
                  <span class="text-[10px] text-[var(--text-muted)] mt-0.5">{tool.desc}</span>
                </a>
              );
            })}
          </div>
        </div>

        <!-- About Link -->
        <a href={aboutLink.href} class={`whitespace-nowrap px-4 py-2.5 text-sm font-bold rounded-full transition-all duration-200 no-underline nav-active-indicator ${Astro.url.pathname === aboutLink.href ? 'active text-[var(--text-primary)] bg-[var(--hover-overlay-strong)]' : 'text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--hover-overlay)]'}`} title={aboutLink.label}>
          {aboutLink.label}
        </a>

        <!-- Desktop Theme Toggle -->
        <button id="theme-toggle-desktop" class="ml-1 xl:ml-2 p-2 rounded-full text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--hover-overlay)] transition-all min-h-[36px] min-w-[36px] flex items-center justify-center cursor-pointer" aria-label="Toggle theme" role="switch" aria-checked="false">
          <svg class="theme-icon-dark" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
          <svg class="theme-icon-light hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        </button>
      </div>

      <!-- Mobile Menu Layout -->
      <div class="flex lg:hidden items-center justify-between w-full">
        <span></span>
        <span class="text-base font-display font-extrabold tracking-tight text-[var(--text-primary)]">🐾 DogBreedAge</span>
        <div class="flex items-center gap-0">
          <button id="theme-toggle-mobile" class="p-2 rounded-full text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-all min-h-[48px] min-w-[48px] flex items-center justify-center cursor-pointer" aria-label="Toggle theme" role="switch" aria-checked="false">
            <svg class="theme-icon-dark" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
            <svg class="theme-icon-light hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          </button>
          <button class="p-2.5 text-[var(--text-secondary)] hover:text-[var(--text-primary)] mobile-menu-btn min-h-[48px] min-w-[48px] flex items-center justify-center cursor-pointer" aria-expanded="false" aria-controls="mobile-menu-panel" aria-label="Toggle menu">
            <svg class="menu-icon-hamburger" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" focusable="false"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            <svg class="menu-icon-close hidden" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" focusable="false"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile Menu Panel -->
    <div id="mobile-menu-panel" class="mobile-menu hidden lg:hidden border-t border-[var(--border-default)] bg-[var(--bg-primary)] max-h-screen overflow-y-auto" style="transition: opacity 0.2s ease, transform 0.2s ease; opacity: 0; transform: translateY(-8px); pointer-events: none;">
      <div class="container-custom py-4 flex flex-col gap-0.5">
        
        <span class="text-[10px] font-bold text-[var(--text-faint)] uppercase px-4 py-1.5">Core Pages</span>
        {primaryLinks.map(link => {
          const isActive = Astro.url.pathname === link.href;
          return (
            <a href={link.href} class={`flex items-center px-4 py-3 text-sm font-bold rounded-lg no-underline min-h-[40px] ${isActive ? 'text-[var(--text-primary)] bg-[var(--hover-overlay-strong)]' : 'text-[var(--text-secondary)]'}`} aria-current={isActive ? 'page' : undefined}>
              {link.label}
            </a>
          );
        })}

        <span class="text-[10px] font-bold text-[var(--text-faint)] uppercase px-4 py-1.5 mt-4">Tools & Health</span>
        {toolLinks.map(tool => {
          const isActive = Astro.url.pathname === tool.href;
          return (
            <a href={tool.href} class={`flex flex-col px-4 py-3 rounded-lg no-underline min-h-[44px] ${isActive ? 'text-[var(--text-primary)] bg-[var(--hover-overlay-strong)]' : 'text-[var(--text-secondary)]'}`} aria-current={isActive ? 'page' : undefined}>
              <span class="text-sm font-bold">{tool.label}</span>
              <span class="text-[10px] text-[var(--text-muted)] mt-0.5">{tool.desc}</span>
            </a>
          );
        })}

        <span class="border-t border-[var(--border-default)] my-2"></span>
        <a href={aboutLink.href} class={`flex items-center px-4 py-3 text-sm font-bold rounded-lg no-underline min-h-[40px] ${Astro.url.pathname === aboutLink.href ? 'text-[var(--text-primary)] bg-[var(--hover-overlay-strong)]' : 'text-[var(--text-secondary)]'}`}>
          {aboutLink.label}
        </a>
      </div>
    </div>
  </nav>
</site-header>

<script>
  class SiteHeader extends HTMLElement {
    connectedCallback() {
      const btn = this.querySelector('.mobile-menu-btn');
      const menu = this.querySelector('.mobile-menu');
      const hamburger = this.querySelector('.menu-icon-hamburger');
      const closeIcon = this.querySelector('.menu-icon-close');
      
      function openMenu() {
        menu.classList.remove('hidden');
        requestAnimationFrame(() => {
          menu.style.opacity = '1';
          menu.style.transform = 'translateY(0)';
          menu.style.pointerEvents = 'auto';
        });
      }
      
      function closeMenu() {
        menu.style.opacity = '0';
        menu.style.transform = 'translateY(-8px)';
        menu.style.pointerEvents = 'none';
        setTimeout(() => { menu.classList.add('hidden'); }, 200);
      }
      
      if (btn && menu) {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const expanded = btn.getAttribute('aria-expanded') === 'true';
          btn.setAttribute('aria-expanded', !expanded);
          if (expanded) {
            closeMenu();
          } else {
            openMenu();
          }
          if (hamburger && closeIcon) {
            hamburger.classList.toggle('hidden');
            closeIcon.classList.toggle('hidden');
          }
        });
        
        document.addEventListener('click', (e) => {
          if (!menu.classList.contains('hidden') && menu.style.opacity !== '0' && !this.contains(e.target)) {
            btn.setAttribute('aria-expanded', 'false');
            closeMenu();
            if (hamburger && closeIcon) {
              hamburger.classList.remove('hidden');
              closeIcon.classList.add('hidden');
            }
          }
        });
      }

      const nav = this.querySelector('#main-nav');
      const inner = nav?.querySelector('.nav-inner');
      let scrollTimer;

      window.addEventListener('scroll', () => {
        cancelAnimationFrame(scrollTimer);
        scrollTimer = requestAnimationFrame(() => {
          if (window.scrollY > 80) {
            nav?.classList.add('scrolled');
            if (inner) inner.style.height = '48px';
          } else {
            nav?.classList.remove('scrolled');
            if (inner) inner.style.height = '';
          }
        });
      }, { passive: true });

      function toggleTheme() {
        const html = document.documentElement;
        const isLight = html.classList.contains('light');
        if (isLight) {
          html.classList.remove('light');
          localStorage.setItem('dogbreedage_theme', 'dark');
        } else {
          html.classList.add('light');
          localStorage.setItem('dogbreedage_theme', 'light');
        }
        updateIcons();
        updateThemeAria();
        const tc = document.getElementById('theme-color');
        if (tc) tc.content = getComputedStyle(document.documentElement).getPropertyValue('--bg-primary').trim() || '#000000';
      }

      function updateIcons() {
        const isLight = document.documentElement.classList.contains('light');
        document.querySelectorAll('.theme-icon-dark').forEach(el => el.classList.toggle('hidden', isLight));
        document.querySelectorAll('.theme-icon-light').forEach(el => el.classList.toggle('hidden', !isLight));
      }

      function updateThemeAria() {
        const isLight = document.documentElement.classList.contains('light');
        document.querySelectorAll('#theme-toggle-desktop, #theme-toggle-mobile').forEach(el => {
          el.setAttribute('aria-checked', isLight ? 'true' : 'false');
        });
      }

      document.querySelectorAll('#theme-toggle-desktop, #theme-toggle-mobile').forEach(el => {
        el.addEventListener('click', toggleTheme);
      });

      updateIcons();
      updateThemeAria();
      const tc = document.getElementById('theme-color');
      if (tc) tc.content = getComputedStyle(document.documentElement).getPropertyValue('--bg-primary').trim() || '#000000';
    }
  }
  customElements.define('site-header', SiteHeader);
</script>
