<section class="container-custom py-10 sm:py-16 text-center page-load-late">
  <h2 class="text-xl sm:text-2xl font-semibold tracking-tight text-[var(--text-primary)] mb-3">Related Calculators</h2>
  <p class="text-sm text-[var(--text-secondary)] mb-6 max-w-lg mx-auto">Explore our breed-specific dog age calculators for the most accurate results tailored to your dog's breed.</p>
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 max-w-3xl mx-auto">
    <a href="/dog-age-chart" class="card p-3 sm:p-4 text-center no-underline hover:border-[var(--border-strong)] transition-all" title="Dog Age Chart by Breed Size">
      <span class="text-xl block mb-1">📊</span>
      <span class="text-xs font-medium text-[var(--text-primary)]">Age Chart</span>
    </a>
    <a href="/compare" class="card p-3 sm:p-4 text-center no-underline hover:border-[var(--border-strong)] transition-all" title="Compare Two Dogs Age">
      <span class="text-xl block mb-1">⚖️</span>
      <span class="text-xs font-medium text-[var(--text-primary)]">Compare Dogs</span>
    </a>
    <a href="/reverse-calculator" class="card p-3 sm:p-4 text-center no-underline hover:border-[var(--border-strong)] transition-all" title="Reverse Dog Age Calculator">
      <span class="text-xl block mb-1">🔄</span>
      <span class="text-xs font-medium text-[var(--text-primary)]">Reverse Calc</span>
    </a>
    <a href="/dog-birthday" class="card p-3 sm:p-4 text-center no-underline hover:border-[var(--border-strong)] transition-all" title="Dog Birthday Countdown">
      <span class="text-xl block mb-1">🎂</span>
      <span class="text-xs font-medium text-[var(--text-primary)]">Birthday Countdown</span>
    </a>
    <a href="/labrador-age-calculator" class="card p-3 sm:p-4 text-center no-underline hover:border-[var(--border-strong)] transition-all" title="Labrador Age Calculator">
      <span class="text-xl block mb-1">🦮</span>
      <span class="text-xs font-medium text-[var(--text-primary)]">Labrador</span>
    </a>
    <a href="/golden-retriever-age-calculator" class="card p-3 sm:p-4 text-center no-underline hover:border-[var(--border-strong)] transition-all" title="Golden Retriever Age Calculator">
      <span class="text-xl block mb-1">🦮</span>
      <span class="text-xs font-medium text-[var(--text-primary)]">Golden Retriever</span>
    </a>
    <a href="/french-bulldog-age-calculator" class="card p-3 sm:p-4 text-center no-underline hover:border-[var(--border-strong)] transition-all" title="French Bulldog Age Calculator">
      <span class="text-xl block mb-1">🐕</span>
      <span class="text-xs font-medium text-[var(--text-primary)]">French Bulldog</span>
    </a>
    <a href="/chihuahua-age-calculator" class="card p-3 sm:p-4 text-center no-underline hover:border-[var(--border-strong)] transition-all" title="Chihuahua Age Calculator">
      <span class="text-xl block mb-1">🐩</span>
      <span class="text-xs font-medium text-[var(--text-primary)]">Chihuahua</span>
    </a>
  </div>
</section>
