---
const footerLinks = {
  pages: [
    { href: '/', label: 'Dog Age Calculator' },
    { href: '/dog-age-chart', label: 'Dog Age Chart' },
    { href: '/compare', label: 'Compare Dogs' },
    { href: '/about', label: 'About Us' },
    { href: '/contact', label: 'Contact' },
  ],
  breeds: [
    { href: '/labrador-age-calculator', label: 'Labrador' },
    { href: '/golden-retriever-age-calculator', label: 'Golden Retriever' },
    { href: '/german-shepherd-age-calculator', label: 'German Shepherd' },
    { href: '/bulldog-age-calculator', label: 'Bulldog' },
    { href: '/poodle-age-calculator', label: 'Poodle' },
    { href: '/beagle-age-calculator', label: 'Beagle' },
    { href: '/chihuahua-age-calculator', label: 'Chihuahua' },
    { href: '/pomeranian-age-calculator', label: 'Pomeranian' },
    { href: '/great-dane-age-calculator', label: 'Great Dane' },
    { href: '/husky-age-calculator', label: 'Husky' },
    { href: '/shih-tzu-age-calculator', label: 'Shih Tzu' },
    { href: '/border-collie-age-calculator', label: 'Border Collie' },
  ],
  legal: [
    { href: '/privacy-policy', label: 'Privacy Policy' },
    { href: '/terms-of-service', label: 'Terms of Service' },
  ],
};
---

<footer class="border-t border-[var(--border-default)] bg-[var(--bg-primary)]">
  <div class="container-custom py-12 sm:py-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
      <div>
        <span class="text-base font-semibold tracking-tight text-[var(--text-primary)]">DOGBREEDAGE</span>
        <p class="mt-3 text-sm text-[var(--text-muted)] leading-relaxed max-w-xs">
          The most accurate dog age calculator by breed size. Science-based formulas backed by veterinary research.
        </p>
      </div>
      <div>
        <h4 class="text-xs font-mono uppercase tracking-wider text-[var(--text-faint)] mb-4 sm:mb-5">Pages</h4>
        <ul class="space-y-2 sm:space-y-2.5">
          {footerLinks.pages.map(link => (
            <li><a href={link.href} class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors no-underline inline-block py-1" title={link.label}>{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="text-xs font-mono uppercase tracking-wider text-[var(--text-faint)] mb-4 sm:mb-5">Breed Calculators</h4>
        <ul class="space-y-2 sm:space-y-2.5">
          {footerLinks.breeds.map(link => (
            <li><a href={link.href} class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors no-underline inline-block py-1" title={link.label}>{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="text-xs font-mono uppercase tracking-wider text-[var(--text-faint)] mb-4 sm:mb-5">Legal</h4>
        <ul class="space-y-2 sm:space-y-2.5">
          {footerLinks.legal.map(link => (
            <li><a href={link.href} class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors no-underline inline-block py-1" title={link.label}>{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>
    <div class="mt-10 sm:mt-16 pt-8 sm:pt-10 border-t border-[var(--border-default)] flex flex-col sm:flex-row items-center justify-between gap-3 sm:gap-4">
      <p class="text-xs text-[var(--text-faint)]">&copy; {new Date().getFullYear()} DOGBREEDAGE.COM. All rights reserved. <span class="ml-2 opacity-50">Last updated: {new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</span></p>
      <p class="text-xs text-[var(--text-faint)]">Dog Age Calculator by Breed Size</p>
    </div>
  </div>
</footer>
