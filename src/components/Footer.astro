---
const footerLinks = {
  pages: [
    { href: '/', label: 'Dog Age Calculator' },
    { href: '/about', label: 'About Us' },
    { href: '/contact', label: 'Contact' },
  ],
  legal: [
    { href: '/privacy-policy', label: 'Privacy Policy' },
    { href: '/terms-of-service', label: 'Terms of Service' },
  ],
};
---

<footer class="border-t border-[#222] bg-[#0a0a0a]">
  <div class="container-custom py-10 sm:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8 sm:gap-10 md:gap-12">
      <div class="sm:col-span-2 md:col-span-1">
        <span class="text-base font-semibold tracking-tight text-white">DOGBREEDAGE</span>
        <p class="mt-3 text-sm text-[#666] leading-relaxed max-w-xs">
          The most accurate dog age calculator by breed size. Science-based formulas backed by veterinary research.
        </p>
      </div>
      <div>
        <h4 class="text-xs font-mono uppercase tracking-wider text-[#555] mb-3 sm:mb-4">Pages</h4>
        <ul class="space-y-2 sm:space-y-2.5">
          {footerLinks.pages.map(link => (
            <li>
              <a href={link.href} class="text-sm text-[#888] hover:text-white transition-colors no-underline inline-block py-1">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="text-xs font-mono uppercase tracking-wider text-[#555] mb-3 sm:mb-4">Legal</h4>
        <ul class="space-y-2 sm:space-y-2.5">
          {footerLinks.legal.map(link => (
            <li>
              <a href={link.href} class="text-sm text-[#888] hover:text-white transition-colors no-underline inline-block py-1">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>
    <div class="mt-8 sm:mt-12 pt-6 sm:pt-8 border-t border-[#222] flex flex-col sm:flex-row items-center justify-between gap-3 sm:gap-4">
      <p class="text-xs text-[#555]">&copy; {new Date().getFullYear()} DOGBREEDAGE.COM. All rights reserved.</p>
      <p class="text-xs text-[#555]">Dog Age Calculator by Breed Size</p>
    </div>
  </div>
</footer>
