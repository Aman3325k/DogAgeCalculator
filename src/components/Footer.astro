---
const footerLinks = {
  pages: [
    { href: '/', label: 'Dog Age Calculator' },
    { href: '/dog-age-chart', label: 'Dog Age Chart' },
    { href: '/compare', label: 'Compare Dogs' },
    { href: '/reverse-calculator', label: 'Reverse Calculator' },
    { href: '/dog-birthday', label: 'Birthday Countdown' },
  ],
  healthTools: [
    { href: '/puppy-weight-calculator', label: 'Puppy Weight Calculator' },
    { href: '/dog-chocolate-toxicity-calculator', label: 'Chocolate Emergency Calc' },
    { href: '/dog-calorie-calculator', label: 'Calorie Requirement Calc' },
    { href: '/biological-age-quiz', label: 'Biological Age Health Quiz' },
    { href: '/embed-widget', label: 'Free Embeddable Widget' },
  ],
  breeds: [
    { href: '/labrador-age-calculator', label: 'Labrador' },
    { href: '/golden-retriever-age-calculator', label: 'Golden Retriever' },
    { href: '/german-shepherd-age-calculator', label: 'German Shepherd' },
    { href: '/bulldog-age-calculator', label: 'Bulldog' },
    { href: '/french-bulldog-age-calculator', label: 'French Bulldog' },
    { href: '/poodle-age-calculator', label: 'Poodle' },
    { href: '/beagle-age-calculator', label: 'Beagle' },
    { href: '/chihuahua-age-calculator', label: 'Chihuahua' },
    { href: '/pomeranian-age-calculator', label: 'Pomeranian' },
    { href: '/yorkshire-terrier-age-calculator', label: 'Yorkshire Terrier' },
    { href: '/pug-age-calculator', label: 'Pug' },
    { href: '/dachshund-age-calculator', label: 'Dachshund' },
    { href: '/rottweiler-age-calculator', label: 'Rottweiler' },
    { href: '/corgi-age-calculator', label: 'Corgi' },
    { href: '/great-dane-age-calculator', label: 'Great Dane' },
    { href: '/husky-age-calculator', label: 'Husky' },
    { href: '/shih-tzu-age-calculator', label: 'Shih Tzu' },
    { href: '/border-collie-age-calculator', label: 'Border Collie' },
  ],
  legal: [
    { href: '/about', label: 'About Us' },
    { href: '/contact', label: 'Contact' },
    { href: '/privacy-policy', label: 'Privacy Policy' },
    { href: '/terms-of-service', label: 'Terms of Service' },
  ],
};
---

<footer class="border-t border-[var(--border-default)] bg-[var(--bg-primary)]">
  <div class="container-custom py-12 sm:py-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-5 gap-8">
      
      <!-- Brand column -->
      <div class="md:col-span-1">
        <span class="text-lg font-display font-extrabold tracking-tight text-[var(--text-primary)] flex items-center gap-1.5">🐾 DogBreedAge</span>
        <p class="mt-4 text-xs text-[var(--text-muted)] leading-relaxed max-w-xs">
          The most accurate dog age calculator by breed size. Science-based formulas backed by peer-reviewed veterinary research.
        </p>
      </div>

      <!-- Pages column -->
      <div>
        <h2 class="text-xs font-mono font-bold uppercase tracking-wider text-[var(--text-faint)] mb-4">Core Pages</h2>
        <ul class="space-y-2.5">
          {footerLinks.pages.map(link => (
            <li><a href={link.href} class="text-xs text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors no-underline inline-block py-0.5" title={link.label}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Health tools column -->
      <div>
        <h2 class="text-xs font-mono font-bold uppercase tracking-wider text-[var(--text-faint)] mb-4">Health Tools</h2>
        <ul class="space-y-2.5">
          {footerLinks.healthTools.map(link => (
            <li><a href={link.href} class="text-xs text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors no-underline inline-block py-0.5" title={link.label}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Breed calculators column -->
      <div>
        <h2 class="text-xs font-mono font-bold uppercase tracking-wider text-[var(--text-faint)] mb-4">Breeds</h2>
        <ul class="grid grid-cols-2 gap-x-2 gap-y-2.5">
          {footerLinks.breeds.map(link => (
            <li><a href={link.href} class="text-xs text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors no-underline inline-block py-0.5" title={link.label}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Legal & Company column -->
      <div>
        <h2 class="text-xs font-mono font-bold uppercase tracking-wider text-[var(--text-faint)] mb-4">Company</h2>
        <ul class="space-y-2.5">
          {footerLinks.legal.map(link => (
            <li><a href={link.href} class="text-xs text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors no-underline inline-block py-0.5" title={link.label}>{link.label}</a></li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Bottom details -->
    <div class="mt-10 sm:mt-16 pt-8 border-t border-[var(--border-default)] flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-[10px] text-[var(--text-faint)]">&copy; {new Date().getFullYear()} DogBreedAge.com. All rights reserved. <span class="ml-2">Last updated: {new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</span></p>
      <p class="text-[10px] text-[var(--text-faint)] flex items-center gap-1">Made with ❤️ and 🐾 for dogs</p>
    </div>
  </div>
</footer>
