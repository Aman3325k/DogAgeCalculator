<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const calcForm = document.getElementById('calc-form');
    const downloadBtn = document.getElementById('download-id-card-btn');
    const btnContainer = document.getElementById('id-card-btn-container');
    
    let selectedDogClass = 'dog-1';
    document.querySelectorAll('.avatar-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.avatar-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        selectedDogClass = btn.dataset.dog;
        const art = document.getElementById('id-card-avatar-art');
        if (art) art.className = 'pixel-avatar ' + selectedDogClass;
      });
    });
    
    function populateCard() {
      const nameInput = document.getElementById('dog-name');
      const breedSelected = document.querySelector('input[name="breed-size"]:checked');
      
      let selectedBreed = 'Mixed Breed';
      if (breedSelected) {
        const optionCard = breedSelected.closest('.size-option');
        if (optionCard && optionCard.querySelector('.font-bold')) {
          selectedBreed = optionCard.querySelector('.font-bold').innerText;
        } else {
          selectedBreed = breedSelected.value.charAt(0).toUpperCase() + breedSelected.value.slice(1) + ' Size';
        }
      }
      
      const humanAge = document.getElementById('human-age')?.innerText || '0';
      const lifeStage = document.getElementById('life-stage')?.innerText || 'Adult';
      
      const mode = document.getElementById('input-mode')?.value;
      let totalDays = 0;
      if (mode === 'birthday') {
        const bday = new Date(document.getElementById('dog-birthday').value);
        if (!isNaN(bday.getTime())) totalDays = Math.floor((new Date() - bday) / (1000 * 60 * 60 * 24));
      } else {
        const y = parseInt(document.getElementById('dog-years')?.value || '0');
        const m = parseInt(document.getElementById('dog-months')?.value || '0');
        totalDays = Math.floor((y * 365.25) + (m * 30.44));
      }
      
      const totalHours = totalDays * 24;
      const totalMinutes = totalHours * 60;
      
      document.getElementById('id-card-name').innerText = nameInput?.value || 'My Good Pup';
      document.getElementById('id-card-breed').innerText = selectedBreed;
      document.getElementById('id-card-human-age').innerText = humanAge;
      document.getElementById('id-card-stage').innerText = lifeStage;
      
      document.getElementById('id-card-days').innerText = totalDays.toLocaleString();
      document.getElementById('id-card-hours').innerText = totalHours.toLocaleString();
      document.getElementById('id-card-minutes').innerText = totalMinutes.toLocaleString();
      document.getElementById('id-card-avatar-art').className = 'pixel-avatar ' + selectedDogClass;
    }

    if (calcForm && btnContainer) {
      calcForm.addEventListener('submit', () => {
        setTimeout(() => { 
          populateCard();
          btnContainer.style.display = 'flex'; 
        }, 800);
      });
    }

    if (downloadBtn) {
      downloadBtn.addEventListener('click', async () => {
        const originalText = downloadBtn.innerHTML;
        downloadBtn.innerHTML = '📸 Generating...';
        downloadBtn.disabled = true;

        try {
          populateCard();

          const canvas = await html2canvas(document.getElementById('dog-id-card'), { 
            scale: 1, 
            backgroundColor: '#000000', 
            logging: false 
          });
          
          const nameInput = document.getElementById('dog-name');
          const link = document.createElement('a');
          const fileNameBase = nameInput?.value ? nameInput.value.replace(/[^a-z0-9]/gi, '-').toLowerCase() + '-' : '';
          link.download = `${fileNameBase}premium-pass.png`;
          link.href = canvas.toDataURL('image/png');
          link.click();
        } catch (err) {
          console.error(err);
          alert('Failed to generate ID card.');
        } finally {
          downloadBtn.innerHTML = originalText;
          downloadBtn.disabled = false;
        }
      });
    }
  });
</script>

<script>
  import '../scripts/calculator-bundle.js';
</script>
