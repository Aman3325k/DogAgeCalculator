---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Dog Birthday Countdown — When is My Dog's Next Birthday?"
  description="Find out exactly how many days until your dog's next birthday or half-birthday. Count down the days to celebrate your dog's milestones accurately."
>
  <section class="container-custom py-10 sm:py-16 md:py-24 pb-20">
    <div class="max-w-2xl mx-auto">
      <p class="text-xs text-[var(--text-muted)] mb-2 sm:mb-4">
        <a href="/" class="text-[var(--text-faint)] hover:text-[var(--text-secondary)] transition-colors no-underline">Home</a>
        <span class="text-[var(--text-faint)] mx-1.5">›</span>
        <span class="text-[var(--text-secondary)]">Dog Birthday Countdown</span>
      </p>
      <span class="inline-block text-xs font-mono uppercase tracking-wider text-[var(--text-faint)] px-4 py-1.5 rounded-full border border-[var(--border-default)] mb-4 sm:mb-6">Birthday Tool</span>
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight text-[var(--text-primary)] mb-4">🎂 Dog Birthday Countdown</h1>
      <p class="text-sm text-[var(--text-secondary)] mb-8 leading-relaxed">
        Enter your dog's birthday and find out exactly how many days until their next birthday — plus their upcoming human-equivalent age milestone. Share the countdown with friends and family!
      </p>

      <div class="card card-glow card-accent-top p-6 sm:p-8 mb-6">
        <form id="birthday-form" class="space-y-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="dog-name-input" class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">
                Dog's Name <span class="text-[var(--text-faint)]">(optional)</span>
              </label>
              <input type="text" id="dog-name-input" class="input-base" placeholder="e.g. Buddy" maxlength="30" />
            </div>
            <div>
              <label for="breed-size-select" class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Breed Size</label>
              <select id="breed-size-select" class="select-base">
                <option value="">Select size…</option>
                <option value="small">Small (under 20 lbs)</option>
                <option value="medium">Medium (20–50 lbs)</option>
                <option value="large">Large (50–90 lbs)</option>
                <option value="giant">Giant (90+ lbs)</option>
              </select>
            </div>
          </div>
          <div>
            <label for="birthday-input" class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">
              Date of Birth
            </label>
            <input type="date" id="birthday-input" class="input-base" />
            <p class="text-xs text-[var(--text-faint)] mt-1">We'll calculate the exact countdown to their next birthday</p>
          </div>
          <button type="submit" class="btn-primary w-full justify-center text-base py-4.5 btn-pulse" id="birthday-submit">
            <span class="btn-shimmer"></span>
            🎂 Show Birthday Countdown
          </button>
        </form>
      </div>

      <!-- Result -->
      <div id="birthday-result" class="hidden space-y-6 fade-in-up" aria-live="polite" aria-atomic="true">
        <!-- Countdown Card -->
        <div class="card overflow-hidden" id="birthday-card">
          <div class="bg-gradient-to-br from-[#7928ca] via-[#ff0080] to-[#f9cb28] p-px rounded-[15px]">
            <div class="bg-[var(--bg-primary)] rounded-[14px] p-6 sm:p-8 text-center">
              <div class="text-4xl mb-4" id="birthday-emoji">🎂</div>
              <p class="text-xs font-mono uppercase tracking-wider text-[var(--text-faint)] mb-1">Next Birthday In</p>
              <div class="flex items-end justify-center gap-4 sm:gap-6 my-4">
                <div class="text-center">
                  <p class="text-5xl sm:text-6xl font-bold tracking-tight text-[var(--text-primary)] leading-none" id="countdown-days">—</p>
                  <p class="text-xs text-[var(--text-muted)] mt-1">days</p>
                </div>
                <div class="text-center mb-2">
                  <p class="text-3xl text-[var(--text-faint)]">:</p>
                </div>
                <div class="text-center">
                  <p class="text-5xl sm:text-6xl font-bold tracking-tight text-[var(--text-primary)] leading-none" id="countdown-hours">—</p>
                  <p class="text-xs text-[var(--text-muted)] mt-1">hours</p>
                </div>
                <div class="text-center mb-2">
                  <p class="text-3xl text-[var(--text-faint)]">:</p>
                </div>
                <div class="text-center">
                  <p class="text-5xl sm:text-6xl font-bold tracking-tight text-[var(--text-primary)] leading-none" id="countdown-mins">—</p>
                  <p class="text-xs text-[var(--text-muted)] mt-1">mins</p>
                </div>
              </div>
              <p class="text-base sm:text-lg font-semibold text-[var(--text-primary)] mb-1" id="birthday-headline">—</p>
              <p class="text-sm text-[var(--text-secondary)]" id="birthday-subline">—</p>
            </div>
          </div>
        </div>

        <!-- Stats Grid -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          <div class="card p-4 text-center">
            <p class="text-xs text-[var(--text-faint)] font-mono uppercase tracking-wider mb-1">Current Age</p>
            <p class="text-lg font-bold text-[var(--text-primary)]" id="stat-current-age">—</p>
          </div>
          <div class="card p-4 text-center">
            <p class="text-xs text-[var(--text-faint)] font-mono uppercase tracking-wider mb-1">Turning</p>
            <p class="text-lg font-bold text-[var(--text-primary)]" id="stat-turning">—</p>
          </div>
          <div class="card p-4 text-center">
            <p class="text-xs text-[var(--text-faint)] font-mono uppercase tracking-wider mb-1">Human Equiv.</p>
            <p class="text-lg font-bold text-[var(--text-primary)]" id="stat-human-age">—</p>
          </div>
          <div class="card p-4 text-center">
            <p class="text-xs text-[var(--text-faint)] font-mono uppercase tracking-wider mb-1">Life Stage</p>
            <p class="text-lg font-bold text-[var(--text-primary)]" id="stat-stage">—</p>
          </div>
        </div>

        <!-- Birthday date -->
        <div class="card p-4 flex items-center gap-4">
          <span class="text-2xl shrink-0">📅</span>
          <div>
            <p class="text-xs text-[var(--text-faint)] font-mono uppercase tracking-wider">Next Birthday</p>
            <p class="text-sm font-medium text-[var(--text-primary)]" id="next-birthday-date">—</p>
          </div>
        </div>

        <!-- Fun fact -->
        <div class="card p-4 flex items-center gap-4">
          <span class="text-2xl shrink-0">🧬</span>
          <div>
            <p class="text-xs text-[var(--text-faint)] font-mono uppercase tracking-wider mb-0.5">Fun Fact</p>
            <p class="text-sm text-[var(--text-secondary)] leading-relaxed" id="birthday-fun-fact">—</p>
          </div>
        </div>

        <!-- Share buttons -->
        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-2 pt-1">
          <button type="button" class="btn-secondary text-sm btn-mobile-full justify-center gap-2" id="share-whatsapp-bd">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Share on WhatsApp
          </button>
          <button type="button" class="btn-secondary text-sm btn-mobile-full justify-center gap-2" id="share-twitter-bd">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Share on X
          </button>
          <button type="button" class="btn-secondary text-sm btn-mobile-full justify-center gap-2" id="copy-countdown-bd">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
            Copy Link
          </button>
        </div>

        <div class="text-center pt-1">
          <button type="button" class="text-sm text-[var(--text-faint)] hover:text-[var(--text-secondary)] transition-colors bg-transparent border-0 cursor-pointer underline underline-offset-2" id="calc-again-bd">
            ← Calculate Another Dog
          </button>
        </div>
      </div>

      <div class="mt-16 pt-8 border-t border-[var(--border-default)] space-y-4 text-sm text-[var(--text-secondary)] leading-relaxed">
        <h2 class="text-lg font-semibold tracking-tight text-[var(--text-primary)]">About Dog Birthdays</h2>
        <p>Dogs don't celebrate birthdays the way humans do, but knowing your dog's birthday helps you track their health milestones, plan vet checkups, and make their day extra special. Many dog owners celebrate their dog's birthday with special treats, new toys, and a doggy-friendly cake.</p>
        <p>The human-equivalent age shown at your dog's next birthday uses the DNA methylation formula, adjusted for breed size. This gives you a scientifically grounded way to relate your dog's aging milestone to a human life stage — so you can truly appreciate where they are in their journey.</p>
      </div>

      <div class="mt-10 pt-8 border-t border-[var(--border-default)]">
        <h2 class="text-base font-semibold tracking-tight text-[var(--text-primary)] mb-4 text-center">More Tools</h2>
        <div class="flex flex-wrap justify-center gap-2">
          <a href="/" class="tag-pill text-xs no-underline" title="Dog Age Calculator">🐾 Dog Age Calculator</a>
          <a href="/reverse-calculator" class="tag-pill text-xs no-underline" title="Reverse Dog Age Calculator">🔄 Reverse Calculator</a>
          <a href="/compare" class="tag-pill text-xs no-underline" title="Compare Two Dogs">⚖️ Compare Dogs</a>
          <a href="/dog-age-chart" class="tag-pill text-xs no-underline" title="Dog Age Chart">📊 Age Chart</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dogbreedage.com" },
    { "@type": "ListItem", "position": 2, "name": "Dog Birthday Countdown", "item": "https://dogbreedage.com/dog-birthday" }
  ]
})} />

<script>
document.addEventListener('DOMContentLoaded', () => {
  const BREED_DATA = {
    small:  { multiplier: 0.85, lifespan: [12, 16], thresholds: [0.5,2,4,8,12,99]  },
    medium: { multiplier: 1.0,  lifespan: [10, 14], thresholds: [0.5,2,4,7,11,99]  },
    large:  { multiplier: 1.15, lifespan: [8,  12], thresholds: [0.5,1.5,3,6,9,99] },
    giant:  { multiplier: 1.3,  lifespan: [7,  10], thresholds: [0.5,1.5,3,5,8,99] },
  };
  const STAGES = ['Puppy','Teenager','Young Adult','Adult','Senior','Elder'];
  const FUN_FACTS = [
    'Dogs age fastest in their first year — a 1-year-old dog is already equivalent to a 31-year-old human!',
    'Small dogs can live up to 16 years, making their birthdays extra special milestones.',
    'Large breed dogs enter their senior years around their 7th birthday.',
    'The oldest dog ever recorded lived to 29.5 years — a Blue Heeler named Bluey.',
    'Giant breeds like Great Danes are considered seniors by their 6th birthday.',
    'Celebrating your dog\'s birthday with a vet visit is one of the best gifts you can give them.',
  ];

  function calcHumanAge(dogYears, size) {
    const b = BREED_DATA[size];
    if (!b) return '—';
    return Math.round((16 * Math.log(Math.max(dogYears, 0.083)) + 31) * b.multiplier * 10) / 10;
  }

  function getStage(dogYears, size) {
    const b = BREED_DATA[size];
    if (!b) return 'Elder';
    for (let i = 0; i < b.thresholds.length; i++) {
      if (dogYears <= b.thresholds[i]) return STAGES[i];
    }
    return 'Elder';
  }

  function getNextBirthday(birthdayDate) {
    const now = new Date();
    const bd = new Date(birthdayDate);
    let next = new Date(now.getFullYear(), bd.getMonth(), bd.getDate());
    if (next <= now) next.setFullYear(now.getFullYear() + 1);
    return next;
  }

  function getCurrentAge(birthdayDate) {
    const now = new Date();
    const bd = new Date(birthdayDate);
    let years = now.getFullYear() - bd.getFullYear();
    let months = now.getMonth() - bd.getMonth();
    if (months < 0) { years--; months += 12; }
    if (now.getDate() < bd.getDate()) { months--; if (months < 0) { years--; months += 12; } }
    return { years, months, total: years + months / 12 };
  }

  function showToast(msg) {
    const container = document.getElementById('toast-container');
    if (!container) return;
    const t = document.createElement('div');
    t.className = 'toast pointer-events-auto bg-[var(--bg-secondary)] border border-[var(--border-default)] rounded-lg px-4 py-2.5 text-sm text-[var(--text-primary)] shadow-lg';
    t.textContent = msg;
    container.appendChild(t);
    setTimeout(() => { t.style.opacity = '0'; t.style.transition = 'opacity 0.3s'; setTimeout(() => t.remove(), 300); }, 3000);
  }

  let countdownInterval = null;
  let shareText = '';

  function startCountdown(nextBirthday) {
    if (countdownInterval) clearInterval(countdownInterval);

    function update() {
      const now = new Date();
      const diff = nextBirthday - now;
      if (diff <= 0) {
        document.getElementById('countdown-days').textContent = '0';
        document.getElementById('countdown-hours').textContent = '00';
        document.getElementById('countdown-mins').textContent = '00';
        clearInterval(countdownInterval);
        return;
      }
      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      document.getElementById('countdown-days').textContent = days;
      document.getElementById('countdown-hours').textContent = String(hours).padStart(2, '0');
      document.getElementById('countdown-mins').textContent = String(mins).padStart(2, '0');
    }
    update();
    countdownInterval = setInterval(update, 60000);
  }

  const form = document.getElementById('birthday-form');
  const resultSection = document.getElementById('birthday-result');

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const name = document.getElementById('dog-name-input').value.trim() || 'Your dog';
    const size = document.getElementById('breed-size-select').value;
    const birthdayVal = document.getElementById('birthday-input').value;

    if (!size) { showToast('Please select a breed size'); return; }
    if (!birthdayVal) { showToast('Please enter your dog\'s birthday'); return; }

    const bd = new Date(birthdayVal);
    const now = new Date();
    if (bd >= now) { showToast('Birthday must be in the past'); return; }
    if ((now - bd) > 40 * 365.25 * 24 * 60 * 60 * 1000) { showToast('Please enter a realistic birthday'); return; }

    const age = getCurrentAge(birthdayVal);
    const nextBirthday = getNextBirthday(birthdayVal);
    const turningAge = age.years + 1;
    const humanAgeAtBirthday = calcHumanAge(turningAge, size);
    const stageAtBirthday = getStage(turningAge, size);
    const currentHumanAge = calcHumanAge(age.total, size);
    const currentStage = getStage(age.total, size);
    const isToday = nextBirthday.toDateString() === now.toDateString() || 
      (new Date(now.getFullYear(), bd.getMonth(), bd.getDate()).toDateString() === now.toDateString());

    const bdEmoji = turningAge >= 12 ? '🎊' : turningAge >= 7 ? '🎁' : turningAge >= 3 ? '🎂' : '🐶';
    document.getElementById('birthday-emoji').textContent = isToday ? '🎉' : bdEmoji;
    document.getElementById('birthday-headline').textContent = isToday
      ? `🎉 Happy Birthday, ${name}!`
      : `${name} turns ${turningAge} on their next birthday!`;
    document.getElementById('birthday-subline').textContent = isToday
      ? `That's equivalent to ${humanAgeAtBirthday} human years — ${stageAtBirthday}!`
      : `Equivalent to ${humanAgeAtBirthday} human years — entering the ${stageAtBirthday} stage`;

    startCountdown(nextBirthday);

    document.getElementById('stat-current-age').textContent =
      age.months > 0 ? `${age.years}y ${age.months}m` : `${age.years} yrs`;
    document.getElementById('stat-turning').textContent = `${turningAge} years`;
    document.getElementById('stat-human-age').textContent = `${currentHumanAge} yrs`;
    document.getElementById('stat-stage').textContent = currentStage;

    const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
    document.getElementById('next-birthday-date').textContent = isToday
      ? 'Today! 🎉'
      : nextBirthday.toLocaleDateString('en-US', options);

    const funFact = FUN_FACTS[Math.floor(Math.random() * FUN_FACTS.length)];
    document.getElementById('birthday-fun-fact').textContent = funFact;

    shareText = `🎂 ${name} turns ${turningAge} on ${nextBirthday.toLocaleDateString('en-US', { month: 'long', day: 'numeric' })}! That's like a ${humanAgeAtBirthday}-year-old human. Count down at dogbreedage.com/dog-birthday`;

    resultSection.classList.remove('hidden');
    setTimeout(() => resultSection.classList.add('visible'), 10);
    resultSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  document.getElementById('share-whatsapp-bd')?.addEventListener('click', () => {
    window.open(`https://wa.me/?text=${encodeURIComponent(shareText)}`, '_blank');
  });

  document.getElementById('share-twitter-bd')?.addEventListener('click', () => {
    window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}`, '_blank');
  });

  document.getElementById('copy-countdown-bd')?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(shareText + ' https://dogbreedage.com/dog-birthday');
      showToast('Countdown copied!');
    } catch {
      showToast('Countdown copied!');
    }
  });

  document.getElementById('calc-again-bd')?.addEventListener('click', () => {
    resultSection.classList.add('hidden');
    if (countdownInterval) clearInterval(countdownInterval);
    form.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
});
</script>
