---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Reverse Dog Age Calculator — Human Age to Dog Years"
  description="Enter a human age and find out exactly how old a dog would be at that life stage. Reverse dog age calculator works for all breed sizes. Fast and free."
>
  <section class="container-custom py-10 sm:py-16 md:py-24 pb-20">
    <div class="max-w-2xl mx-auto">
      <p class="text-xs text-[var(--text-muted)] mb-2 sm:mb-4">
        <a href="/" class="text-[var(--text-faint)] hover:text-[var(--text-secondary)] transition-colors no-underline">Home</a>
        <span class="text-[var(--text-faint)] mx-1.5">›</span>
        <span class="text-[var(--text-secondary)]">Reverse Dog Age Calculator</span>
      </p>
      <span class="inline-block text-xs font-mono uppercase tracking-wider text-[var(--text-faint)] px-4 py-1.5 rounded-full border border-[var(--border-default)] mb-4 sm:mb-6">Reverse Calculator</span>
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight text-[var(--text-primary)] mb-4">Reverse Dog Age Calculator</h1>
      <p class="text-sm text-[var(--text-secondary)] mb-8 leading-relaxed max-w-xl">
        Enter a human age and find out how old a dog would be at an equivalent life stage — across all four breed sizes. Useful for understanding where your dog sits in their life journey compared to humans.
      </p>

      <div class="card card-glow p-6 sm:p-8 mb-8">
        <form id="reverse-form" class="space-y-6">
          <div>
            <label for="human-age-input" class="block text-sm font-medium text-[var(--text-secondary)] mb-2">
              Human Age <span class="text-[var(--text-faint)]">(years)</span>
            </label>
            <div class="flex items-center gap-4">
              <input
                type="number"
                id="human-age-input"
                class="input-base flex-1"
                placeholder="e.g. 35"
                min="1"
                max="120"
                required
              />
              <button type="submit" class="btn-primary px-6 shrink-0">
                <span class="btn-shimmer"></span>
                Convert →
              </button>
            </div>
            <p class="text-xs text-[var(--text-faint)] mt-1.5">Enter any age between 1 and 120</p>
          </div>
        </form>
      </div>

      <div id="reverse-result" class="hidden space-y-4 fade-in-up" aria-live="polite" aria-atomic="true">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-sm font-medium text-[var(--text-secondary)]">A human aged <strong id="display-human-age" class="text-[var(--text-primary)]">—</strong> is equivalent to a dog aged:</span>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4" id="result-cards">
          {['small','medium','large','giant'].map(size => (
            <div class={`card p-4 sm:p-6 result-size-card`} data-size={size}>
              <div class="flex items-start justify-between mb-4">
                <div>
                  <span class="text-xs font-mono uppercase tracking-wider text-[var(--text-faint)]" id={`${size}-label`}>—</span>
                  <p class="text-[0.7rem] text-[var(--text-muted)]" id={`${size}-weight`}>—</p>
                </div>
                <span class="text-2xl" id={`${size}-icon`}>—</span>
              </div>
              <p class="text-3xl font-display font-extrabold tracking-tight text-[var(--btn-primary-bg)] mb-1" id={`${size}-dog-age`}>—</p>
              <p class="text-xs text-[var(--text-muted)] font-bold">dog years old</p>
              <div class="flex items-center gap-1.5 mt-4 pt-4 border-t border-[var(--border-default)]">
                <span class="text-xs text-[var(--text-secondary)] font-bold">Life stage:</span>
                <span id={`${size}-stage`} class="stage-pill text-[0.75rem] py-1 px-2.5">—</span>
              </div>
              <div class="mt-3">
                <div class="progress-bar">
                  <div class="progress-bar-fill bg-gradient-to-r from-[var(--gradient-from)] to-[var(--gradient-to)]" id={`${size}-progress`} style="width:0%"></div>
                </div>
                <p class="text-[0.65rem] text-[var(--text-faint)] mt-1" id={`${size}-lifespan`}>—</p>
              </div>
            </div>
          ))}
        </div>

        <div class="card p-4 mt-2">
          <p class="text-xs text-[var(--text-faint)] font-mono uppercase tracking-wider mb-2">How to read this</p>
          <p class="text-sm text-[var(--text-secondary)] leading-relaxed">
            The reverse calculation uses the inverse of the DNA methylation formula: <code class="text-xs bg-[var(--bg-elevated)] px-1.5 py-0.5 rounded">dog_age = e^((human_age / multiplier − 31) / 16)</code>. Results show the dog age at which each breed size reaches the equivalent human life stage.
          </p>
        </div>

        <div class="text-center pt-2">
          <a href="/" class="btn-secondary text-sm no-underline inline-flex items-center gap-2">
            🐾 Try the full Dog Age Calculator
          </a>
        </div>
      </div>

      <div class="mt-16 pt-8 border-t border-[var(--border-default)] space-y-6 text-sm text-[var(--text-secondary)] leading-relaxed">
        <h2 class="text-lg font-semibold tracking-tight text-[var(--text-primary)]">About Reverse Dog Age Calculation</h2>
        <p>The standard dog age formula converts a dog's age into human equivalent years: <strong class="text-[var(--text-primary)]">Human Age = 16 × ln(Dog Age) + 31</strong> (adjusted by breed size). The reverse calculator flips this: given a human age, it solves for the dog age using the inverse of the natural logarithm.</p>
        <p>This is useful for understanding life stage comparisons. For example: if you're 35 years old, what age is your dog at the same "life position"? The answer differs dramatically by breed — a small dog at 4.5 years is roughly equivalent to a 35-year-old human, while a giant breed reaches that same human life stage at just 3.2 years.</p>
        <p>The reverse calculator is especially useful for new dog owners trying to understand their puppy's development pace, or senior owners trying to relate to their dog's aging trajectory.</p>
      </div>

      <div class="mt-12 pt-8 border-t border-[var(--border-default)]">
        <h2 class="text-base font-semibold tracking-tight text-[var(--text-primary)] mb-4 text-center">Related Tools</h2>
        <div class="flex flex-wrap justify-center gap-2">
          <a href="/" class="tag-pill text-xs no-underline" title="Dog Age Calculator">🐾 Dog Age Calculator</a>
          <a href="/compare" class="tag-pill text-xs no-underline" title="Compare Two Dogs">⚖️ Compare Dogs</a>
          <a href="/dog-birthday" class="tag-pill text-xs no-underline" title="Dog Birthday Countdown">🎂 Birthday Countdown</a>
          <a href="/dog-age-chart" class="tag-pill text-xs no-underline" title="Dog Age Chart">📊 Age Chart</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dogbreedage.com" },
    { "@type": "ListItem", "position": 2, "name": "Reverse Dog Age Calculator", "item": "https://dogbreedage.com/reverse-calculator" }
  ]
})} />

<script>
import { BREED_SIZES, getLifeStage } from '../scripts/breed-data.js';

(() => {
  const SIZES = {
    small:  { label: 'Small Breed',  weight: 'under 20 lbs',  icon: '🐩' },
    medium: { label: 'Medium Breed', weight: '20–50 lbs',     icon: '🐕' },
    large:  { label: 'Large Breed',  weight: '50–90 lbs',     icon: '🦮' },
    giant:  { label: 'Giant Breed',  weight: '90+ lbs',       icon: '🐘' },
  };

  function reverseDogAge(humanAge, multiplier) {
    // Inverse of: humanAge = (16 * ln(dogAge) + 31) * multiplier
    const adjusted = humanAge / multiplier;
    const dogAge = Math.exp((adjusted - 31) / 16);
    return Math.max(0.08, dogAge);
  }

  const form = document.getElementById('reverse-form');
  const resultSection = document.getElementById('reverse-result');
  const displayHumanAge = document.getElementById('display-human-age');

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const humanAge = parseFloat(document.getElementById('human-age-input').value);
    if (isNaN(humanAge) || humanAge < 1 || humanAge > 120) {
      alert('Please enter a valid age between 1 and 120');
      return;
    }

    displayHumanAge.textContent = Math.round(humanAge);

    for (const [size, uiData] of Object.entries(SIZES)) {
      const data = BREED_SIZES[size];
      const dogAge = reverseDogAge(humanAge, data.multiplier);
      const dogAgeYears = Math.floor(dogAge);
      const dogAgeMonths = Math.round((dogAge - dogAgeYears) * 12);
      const stage = getLifeStage(dogAge, size);
      const progress = Math.min(100, (dogAge / data.lifespan[1]) * 100);

      document.getElementById(`${size}-label`).textContent = uiData.label;
      document.getElementById(`${size}-weight`).textContent = uiData.weight;
      document.getElementById(`${size}-icon`).textContent = uiData.icon;
      document.getElementById(`${size}-dog-age`).textContent =
        dogAgeMonths > 0 ? `${dogAgeYears}y ${dogAgeMonths}m` : `${dogAgeYears} yrs`;
      const stageEl = document.getElementById(`${size}-stage`);
      stageEl.textContent = stage;
      stageEl.className = 'stage-pill text-[0.75rem] py-1 px-2.5 stage-' + stage.replace(' ', '-');
      document.getElementById(`${size}-progress`).style.width = `${progress}%`;
      document.getElementById(`${size}-lifespan`).textContent =
        `Typical lifespan: ${data.lifespan[0]}–${data.lifespan[1]} years`;
    }

    resultSection.classList.remove('hidden');
    setTimeout(() => resultSection.classList.add('visible'), 10);
    resultSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
})();
</script>
