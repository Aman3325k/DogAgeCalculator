---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Terms of Service"
  description="Read the Terms of Service for DOGBREEDAGE. By using our website and accurate dog age calculators, you agree to these standard terms."
>
  <section class="container-custom py-10 sm:py-16 md:py-24 pb-20">
    <div class="max-w-2xl mx-auto px-0 sm:px-1">
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebPage",
        "name": "Terms of Service",
        "description": "Terms of Service for DOGBREEDAGE. By using our website, you agree to these terms.",
        "url": "https://dogbreedage.com/terms-of-service",
        "author": { "@type": "Organization", "name": "DOGBREEDAGE", "url": "https://dogbreedage.com" },
        "publisher": { "@type": "Organization", "name": "DOGBREEDAGE", "url": "https://dogbreedage.com" },
        "datePublished": "2025-01-15",
        "dateModified": new Date().toISOString().split('T')[0]
      })} />
      <span class="inline-block text-xs font-mono uppercase tracking-wider text-[var(--text-faint)] px-4 py-1.5 rounded-full border border-[var(--border-default)] mb-4 sm:mb-6">Legal</span>
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight text-[var(--text-primary)] mb-6 sm:mb-8">Terms of Service</h1>
      <div class="space-y-4 sm:space-y-6 text-sm text-[var(--text-secondary)] leading-relaxed">
        <p><strong class="text-[var(--text-primary)]">Effective Date:</strong> January 1, 2025</p>
        <p>
          By using the DOGBREEDAGE website, you agree to the following terms and conditions.
        </p>
        <h2 class="text-base sm:text-lg font-semibold tracking-tight text-[var(--text-primary)]">Use of Service</h2>
        <p>
          DOGBREEDAGE provides a free dog age calculator tool for informational and entertainment purposes. The calculator is intended to provide an estimate based on current veterinary research and should not replace professional veterinary advice.
        </p>
        <h2 class="text-base sm:text-lg font-semibold tracking-tight text-[var(--text-primary)]">No Medical Advice</h2>
        <p>
          The information provided by our calculator and educational content is not veterinary medical advice. Always consult with a licensed veterinarian for health decisions regarding your pet.
        </p>
        <h2 class="text-base sm:text-lg font-semibold tracking-tight text-[var(--text-primary)]">Intellectual Property</h2>
        <p>
          All content on this website, including text, graphics, and the calculator tool, is the property of DOGBREEDAGE and is protected by applicable copyright laws.
        </p>
        <h2 class="text-base sm:text-lg font-semibold tracking-tight text-[var(--text-primary)]">Limitation of Liability</h2>
        <p>
          DOGBREEDAGE provides the calculator and content on an "as is" basis. We make no warranties regarding the accuracy, completeness, or reliability of the results. We shall not be liable for any damages arising from the use of this website.
        </p>
        <h2 class="text-base sm:text-lg font-semibold tracking-tight text-[var(--text-primary)]">Changes to Terms</h2>
        <p>
          We reserve the right to modify these terms at any time. Continued use of the website after changes constitutes acceptance of the new terms.
        </p>
        <h2 class="text-base sm:text-lg font-semibold tracking-tight text-[var(--text-primary)]">Contact</h2>
        <p>
          For questions about these terms, please <a href="/contact" class="text-[var(--color-link)] hover:underline" title="Contact DOGBREEDAGE">contact us</a>.
        </p>
      </div>
    </div>
  </section>

  <section class="container-custom pb-20">
    <div class="max-w-2xl mx-auto card p-6 sm:p-6 text-center">
      <p class="text-sm text-[var(--text-secondary)] mb-4">Ready to try the most accurate dog age calculator?</p>
      <a href="/" class="btn-primary text-sm no-underline inline-flex">Try the Calculator →</a>
    </div>
  </section>
</BaseLayout>
