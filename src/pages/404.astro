---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist on DOGBREEDAGE."
>
  <section class="container-custom py-20 sm:py-24 md:py-32 text-center">
    <span class="text-6xl sm:text-8xl font-bold tracking-tight text-white/10 block mb-4 sm:mb-6">404</span>
    <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight text-white mb-3 sm:mb-4">Page Not Found</h1>
    <p class="text-sm sm:text-base text-[#888] max-w-md mx-auto mb-8 sm:mb-10 px-4">
      The page you're looking for doesn't exist or has been moved. Let's get you back on track.
    </p>
    <a href="/" class="btn-primary text-sm sm:text-base">Go to Calculator</a>
  </section>
</BaseLayout>
