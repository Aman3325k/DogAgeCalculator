---
import BaseLayout from '../layouts/BaseLayout.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const breedSizes = [
  { value: 'small', label: 'Small', desc: 'under 20 lbs' },
  { value: 'medium', label: 'Medium', desc: '20-50 lbs' },
  { value: 'large', label: 'Large', desc: '50-90 lbs' },
  { value: 'giant', label: 'Giant', desc: '90+ lbs' },
];
---

<BaseLayout
  title="Compare Two Dogs — Dog Age Calculator"
  description="Compare two dogs' ages in human years side-by-side using our breed-size accurate calculator. See how different breeds age biologically. Free to use."
>
  <section class="container-custom py-10 sm:py-16 md:py-24 pb-20">
    <div class="max-w-5xl mx-auto">
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebPage",
        "name": "Compare Two Dogs — Dog Age Calculator",
        "description": "Compare two dogs' ages side by side. See which dog is older in human years with our breed-size based comparison tool.",
        "url": "https://dogbreedage.com/compare",
        "author": { "@type": "Organization", "name": "DOGBREEDAGE", "url": "https://dogbreedage.com" },
        "publisher": { "@type": "Organization", "name": "DOGBREEDAGE", "url": "https://dogbreedage.com" },
        "datePublished": "2025-01-15",
        "dateModified": new Date().toISOString().split('T')[0]
      })} />
      <span class="inline-block text-xs font-mono uppercase tracking-wider text-[var(--text-faint)] px-4 py-1.5 rounded-full border border-[var(--border-default)] mb-4 sm:mb-6">Compare Dogs</span>
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight text-[var(--text-primary)] mb-4">Compare Two Dogs</h1>
      <p class="text-sm text-[var(--text-secondary)] mb-8 max-w-xl leading-relaxed">Compare the human age of two dogs side by side. See which one is older, their life stages, and life expectancy differences.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="compare-root">
        {[1, 2].map(num => (
          <div class="card card-hover-lift p-4 sm:p-6 md:p-8" data-compare={num}>
            <h2 class="text-sm font-semibold text-[var(--text-primary)] mb-6">Dog {num}</h2>
              <div class="space-y-6">
              <div>
                <label class="block text-xs font-medium text-[var(--text-secondary)] mb-1">Name</label>
                <input type="text" class="input-base text-sm py-2" id={`c${num}-name`} placeholder={`Dog ${num}`} maxlength="30" />
              </div>
              <div>
                <label class="block text-xs font-medium text-[var(--text-secondary)] mb-1.5">Breed Size</label>
                <div class="grid grid-cols-2 gap-1.5">
                  {breedSizes.map(bs => (
                    <label class="flex flex-col items-center justify-center p-2 rounded-lg border border-[var(--border-default)] bg-[var(--bg-secondary)] cursor-pointer transition-all hover:border-[var(--border-strong)] has-[:checked]:border-[var(--text-primary)] has-[:checked]:bg-[var(--hover-overlay)] min-h-[52px]">
                      <input type="radio" name={`c${num}-size`} value={bs.value} class="hidden" />
                      <span class="text-xs font-medium text-[var(--text-primary)] leading-tight text-center">{bs.label}</span>
                      <span class="text-[0.625rem] text-[var(--text-muted)] text-center leading-tight">{bs.desc}</span>
                    </label>
                  ))}
                </div>
              </div>
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="block text-xs font-medium text-[var(--text-secondary)] mb-1">Years</label>
                  <input type="number" class="input-base text-sm py-2" id={`c${num}-years`} min="0" max="40" placeholder="0" />
                </div>
                <div>
                  <label class="block text-xs font-medium text-[var(--text-secondary)] mb-1">Months</label>
                  <select class="select-base text-sm py-2" id={`c${num}-months`}>
                    {Array.from({ length: 12 }, (_, i) => <option value={i}>{i === 0 ? '0 months' : i === 1 ? '1 month' : `${i} months`}</option>)}
                  </select>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="flex justify-center mt-6">
        <button type="button" class="btn-primary text-base py-4 px-8" id="compare-btn">Compare Ages</button>
      </div>

        <div id="compare-result" class="hidden mt-10 space-y-6" aria-live="polite" aria-atomic="true">
        <div class="card p-6 card-hover-lift">
          <h2 class="text-lg font-semibold tracking-tight text-[var(--text-primary)] mb-6">Comparison Results</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div id="compare-card-1" class="card card-hover-lift p-4 border-[var(--border-strong)]"></div>
            <div id="compare-card-2" class="card card-hover-lift p-4 border-[var(--border-strong)]"></div>
          </div>
          <div class="mt-6 pt-6 border-t border-[var(--border-default)] text-center">
            <p class="text-lg font-semibold text-[var(--text-primary)]" id="compare-winner"></p>
            <p class="text-sm text-[var(--text-secondary)] mt-1" id="compare-fun-msg"></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-custom pb-20">
    <div class="max-w-2xl mx-auto card p-6 sm:p-6 text-center">
      <p class="text-sm text-[var(--text-secondary)] mb-4">Want to calculate your own dog's age?</p>
      <a href="/" class="btn-primary text-sm no-underline inline-flex">Try the Calculator →</a>
    </div>
  </section>

  <div class="section-divider max-w-2xl mb-10 sm:mb-16"></div>
  <RelatedCalculators />

</BaseLayout>

<script>
import { BREED_SIZES, calcDogAge, getLifeStage } from '../scripts/breed-data.js';

(() => {

  document.getElementById('compare-btn').addEventListener('click', () => {
    const results = [];
    for (let n = 1; n <= 2; n++) {
      const nameEl = document.getElementById(`c${n}-name`);
      const yearsEl = document.getElementById(`c${n}-years`);
      const monthsEl = document.getElementById(`c${n}-months`);
      const sizeRadio = document.querySelector(`input[name="c${n}-size"]:checked`);
      if (!nameEl || !yearsEl || !monthsEl) return;
      const name = nameEl.value.trim() || `Dog ${n}`;
      if (!sizeRadio) { alert(`Please select a breed size for Dog ${n}`); return; }
      const size = sizeRadio.value;
      const years = parseInt(yearsEl.value);
      const months = parseInt(monthsEl.value);
      if (yearsEl.value === '' || isNaN(years) || years < 0) { alert(`Please enter a valid age for Dog ${n}`); return; }
      if (years > 40) { alert(`Age must be 40 years or less for Dog ${n}`); return; }
      if (years === 0 && months === 0) { alert(`Age must be greater than 0 for Dog ${n}`); return; }
      if (years === 0 && isNaN(months)) { alert(`Please select months for Dog ${n}`); return; }
      const total = years + months / 12;
      const ha = calcDogAge(years, months, BREED_SIZES[size].multiplier);
      results.push({ name, size, total, ha, stage: getLifeStage(total, size), lifespan: BREED_SIZES[size].lifespan });
    }

    const c1 = document.getElementById('compare-card-1');
    const c2 = document.getElementById('compare-card-2');
    if (!c1 || !c2) return;

    [0,1].forEach(i => {
      const r = results[i];
      const el = i === 0 ? c1 : c2;
      el.innerHTML = '';
      const nameP = document.createElement('p');
      nameP.className = 'text-base font-semibold text-[var(--text-primary)] mb-2';
      nameP.textContent = r.name;
      el.appendChild(nameP);
      const infoP = document.createElement('p');
      infoP.className = 'text-xs text-[var(--text-muted)] mb-1';
      infoP.textContent = `${BREED_SIZES[r.size]?.label || 'Unknown'} breed · ${r.total.toFixed(1)} dog years`;
      el.appendChild(infoP);
      const ageP = document.createElement('p');
      ageP.className = 'text-3xl font-bold text-[var(--text-primary)] my-2';
      ageP.innerHTML = `${r.ha} <span class="text-sm font-normal text-[var(--text-secondary)]">human years</span>`;
      el.appendChild(ageP);
      const stageP = document.createElement('p');
      stageP.className = 'text-xs px-2 py-0.5 rounded-full inline-block bg-[var(--hover-overlay-strong)] text-[var(--text-primary)]';
      stageP.textContent = r.stage;
      el.appendChild(stageP);
      const lifeP = document.createElement('p');
      lifeP.className = 'text-xs text-[var(--text-faint)] mt-2';
      lifeP.textContent = `Life expectancy: ${r.lifespan[0]}-${r.lifespan[1]} years`;
      el.appendChild(lifeP);
    });

    const winnerEl = document.getElementById('compare-winner');
    const funMsgEl = document.getElementById('compare-fun-msg');
    const resultEl = document.getElementById('compare-result');
    if (!winnerEl || !funMsgEl || !resultEl) return;

    let winner, msg;
    if (results[0].ha > results[1].ha) {
      winner = `${results[0].name} is older in human years (${results[0].ha} vs ${results[1].ha})`;
      msg = `${results[0].name} has lived ${(results[0].ha - results[1].ha).toFixed(1)} more human years than ${results[1].name}.`;
    } else if (results[1].ha > results[0].ha) {
      winner = `${results[1].name} is older in human years (${results[1].ha} vs ${results[0].ha})`;
      msg = `${results[1].name} has lived ${(results[1].ha - results[0].ha).toFixed(1)} more human years than ${results[0].name}.`;
    } else {
      winner = `Both dogs are the same human age!`;
      msg = `What a coincidence — ${results[0].name} and ${results[1].name} are the same age in human years!`;
    }

    winnerEl.textContent = winner;
    funMsgEl.textContent = msg;
    resultEl.classList.remove('hidden');
    resultEl.scrollIntoView({ behavior: 'smooth' });
  });
})();
</script>
