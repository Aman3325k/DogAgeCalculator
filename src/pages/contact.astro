---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us"
  description="Contact DOGBREEDAGE. Get in touch with questions, feedback, or suggestions."
>
  <section class="container-custom py-10 sm:py-16 md:py-24">
    <div class="max-w-2xl mx-auto px-0 sm:px-1">
      <span class="inline-block text-xs font-mono uppercase tracking-wider text-[var(--text-faint)] px-3 py-1.5 rounded-full border border-[var(--border-default)] mb-4 sm:mb-6">Contact</span>
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight text-[var(--text-primary)] mb-3 sm:mb-4">Contact Us</h1>
      <p class="text-sm text-[var(--text-secondary)] mb-8 sm:mb-10 max-w-md">
        Have questions, feedback, or suggestions? We'd love to hear from you. Fill out the form below and we'll get back to you.
      </p>
      <form class="card p-4 sm:p-6 md:p-8 space-y-5 sm:space-y-6" data-netlify="true" name="contact">
        <input type="hidden" name="form-name" value="contact" />
        <div>
          <label for="name" class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Name</label>
          <input type="text" id="name" name="name" class="input-base" placeholder="Your name" required />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Email</label>
          <input type="email" id="email" name="email" class="input-base" placeholder="your@email.com" required />
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Message</label>
          <textarea id="message" name="message" class="input-base min-h-[120px] sm:min-h-[140px] resize-y" placeholder="Your message..." required></textarea>
        </div>
        <button type="submit" class="btn-primary w-full justify-center text-base py-3.5 sm:py-3">Send Message</button>
      </form>
    </div>
  </section>
</BaseLayout>
