---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us"
  description="Contact DOGBREEDAGE. Get in touch with questions, feedback, or suggestions. We respond quickly — reach out today."
>
  <section class="container-custom py-10 sm:py-16 md:py-24 pb-20">
    <div class="max-w-2xl mx-auto px-0 sm:px-1">
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ContactPage",
        "name": "Contact DOGBREEDAGE",
        "description": "Contact DOGBREEDAGE. Get in touch with questions, feedback, or suggestions about our dog age calculator.",
        "url": "https://dogbreedage.com/contact",
        "author": { "@type": "Organization", "name": "DOGBREEDAGE", "url": "https://dogbreedage.com" },
        "publisher": { "@type": "Organization", "name": "DOGBREEDAGE", "url": "https://dogbreedage.com" },
        "datePublished": "2025-01-15",
        "dateModified": new Date().toISOString().split('T')[0]
      })} />
      <span class="inline-block text-xs font-mono uppercase tracking-wider text-[var(--text-faint)] px-3 py-1.5 rounded-full border border-[var(--border-default)] mb-4 sm:mb-6">Contact</span>
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight text-[var(--text-primary)] mb-3 sm:mb-4">Contact Us</h1>
      <p class="text-sm text-[var(--text-secondary)] mb-8 sm:mb-10 max-w-md">
        Have questions, feedback, or suggestions? We'd love to hear from you. Fill out the form below and we'll get back to you.
      </p>

      <div id="contact-form-status"></div>

      <form id="contact-form" class="card p-4 sm:p-6 md:p-8 space-y-5 sm:space-y-6" method="POST">
        <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_KEY">
        <input type="hidden" name="subject" value="New Contact from DOGBREEDAGE.COM">
        <input type="hidden" name="redirect" value="false">
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off">
        <div>
          <label for="name" class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Name</label>
          <input type="text" id="name" name="name" class="input-base" placeholder="Your name" required />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Email</label>
          <input type="email" id="email" name="email" class="input-base" placeholder="your@email.com" required />
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Message</label>
          <textarea id="message" name="message" class="input-base min-h-[120px] sm:min-h-[140px] resize-y" placeholder="Your message..." required></textarea>
        </div>
        <button type="submit" id="contact-submit" class="btn-primary w-full justify-center text-base py-3.5 sm:py-3">
          <span id="contact-btn-text">Send Message</span>
          <span id="contact-spinner" class="hidden spinner"></span>
        </button>
        <p class="text-xs text-center text-[var(--text-faint)]">Powered by Web3Forms — your message goes directly to our email. No data stored on our servers.</p>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const form = document.getElementById('contact-form');
  const statusEl = document.getElementById('contact-form-status');
  const submitBtn = document.getElementById('contact-submit');
  const btnText = document.getElementById('contact-btn-text');
  const spinner = document.getElementById('contact-spinner');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    btnText.textContent = 'Sending...';
    spinner.classList.remove('hidden');

    statusEl.innerHTML = '';

    const formData = new FormData(form);
    const data = Object.fromEntries(formData);

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await response.json();

      if (response.ok && result.success) {
        statusEl.innerHTML = '<div class="card p-4 mb-6 text-center border border-[var(--border-default)]"><p class="text-sm text-[var(--text-primary)] font-medium">Message sent successfully!</p><p class="text-xs text-[var(--text-secondary)] mt-1">We will get back to you as soon as possible.</p></div>';
        form.reset();
      } else {
        throw new Error(result.message || 'Submission failed');
      }
    } catch (err) {
      statusEl.innerHTML = '<div class="card p-4 mb-6 text-center border border-[var(--border-default)]"><p class="text-sm text-[var(--stage-elder)] font-medium">Something went wrong.</p><p class="text-xs text-[var(--text-secondary)] mt-1">Please try again later or email us directly.</p></div>';
    } finally {
      submitBtn.disabled = false;
      btnText.textContent = 'Send Message';
      spinner.classList.add('hidden');
    }
  });
});
</script>
