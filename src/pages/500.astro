---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Server Error"
  description="Something went wrong on DOGBREEDAGE. Please try again."
>
  <section class="container-custom py-20 sm:py-24 md:py-32 text-center pb-20">
    <span class="text-6xl sm:text-8xl font-bold tracking-tight text-[var(--text-primary)]/10 block mb-4 sm:mb-6">500</span>
    <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight text-[var(--text-primary)] mb-3 sm:mb-4">Something Went Wrong</h1>
    <p class="text-sm sm:text-base text-[var(--text-secondary)] max-w-md mx-auto mb-8 sm:mb-10 px-4">
      An unexpected error occurred. Please try refreshing the page or come back later.
    </p>
    <a href="/" class="btn-primary text-sm sm:text-base">Go to Calculator</a>
  </section>
</BaseLayout>
