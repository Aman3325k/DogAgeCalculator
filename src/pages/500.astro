---
import BaseLayout from '../layouts/BaseLayout.astro';

Astro.response.status = 500;
---

<BaseLayout
  title="Server Error"
  description="Internal server error. Please return to the homepage to use our highly accurate dog age calculator based on breed size."
  noindex={true}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dogbreedage.com/" }
    ]
  })} />

  <section class="container-custom py-16 sm:py-20 md:py-28 hero-pattern">
    <div class="max-w-2xl mx-auto text-center flex flex-col items-center gap-6 sm:gap-8">
      <!-- Sleeping dog illustration -->
      <div class="relative" aria-hidden="true">
        <svg class="w-28 h-28 sm:w-36 sm:h-36 md:w-40 md:h-40 error-sleep-breathe" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Body -->
          <ellipse cx="60" cy="70" rx="42" ry="28" fill="currentColor" opacity="0.12"/>
          <!-- Dog body curve -->
          <path d="M30 72 C30 50 50 42 70 46 C85 49 95 58 95 72 C95 82 80 88 60 88 C40 88 30 82 30 72Z" fill="currentColor" opacity="0.18"/>
          <!-- Head -->
          <ellipse cx="82" cy="54" rx="20" ry="18" fill="currentColor" opacity="0.2"/>
          <!-- Ear back -->
          <ellipse cx="70" cy="40" rx="8" ry="16" transform="rotate(-20 70 40)" fill="currentColor" opacity="0.15"/>
          <!-- Ear front -->
          <ellipse cx="82" cy="38" rx="7" ry="14" transform="rotate(-10 82 38)" fill="currentColor" opacity="0.15"/>
          <!-- Nose -->
          <ellipse cx="98" cy="56" rx="4" ry="3" fill="currentColor" opacity="0.35"/>
          <!-- Closed eyes (sleeping) -->
          <path d="M78 50 Q80 47 82 50" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.4"/>
          <path d="M86 50 Q88 47 90 50" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.4"/>
          <!-- Tail -->
          <path d="M30 70 C20 60 18 50 22 46" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none" opacity="0.2"/>
          <!-- Legs tucked -->
          <ellipse cx="40" cy="88" rx="8" ry="5" fill="currentColor" opacity="0.12"/>
          <ellipse cx="56" cy="90" rx="8" ry="5" fill="currentColor" opacity="0.12"/>
          <!-- Z's floating -->
          <text x="88" y="32" font-size="11" font-weight="bold" fill="currentColor" opacity="0.2" class="error-z-1">z</text>
          <text x="96" y="22" font-size="14" font-weight="bold" fill="currentColor" opacity="0.25" class="error-z-2">z</text>
          <text x="105" y="10" font-size="18" font-weight="bold" fill="currentColor" opacity="0.3" class="error-z-3">z</text>
        </svg>
      </div>

      <span class="text-xs sm:text-sm font-mono uppercase tracking-[0.15em] text-[var(--text-faint)]">500 Error</span>

      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-[var(--text-primary)] leading-tight">
        Something Went Wrong
      </h1>

      <p class="text-base sm:text-lg text-[var(--text-secondary)] max-w-md leading-relaxed">
        Even the best dogs need a rest sometimes. Our server is taking a nap — we're on it!
      </p>

      <!-- Action buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-4 w-full sm:w-auto mt-2">
        <button type="button" class="btn-primary text-sm sm:text-base w-full sm:w-auto justify-center" onclick="window.location.reload()" aria-label="Try refreshing the page">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
          Try Again
        </button>
        <a href="/" class="btn-secondary text-sm sm:text-base w-full sm:w-auto justify-center no-underline" aria-label="Go to homepage">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Go Home
        </a>
      </div>

      <!-- Reassurance -->
      <div class="card p-6 sm:p-6 w-full mt-4 sm:mt-6">
        <div class="flex items-start gap-4">
          <span class="text-xl shrink-0 mt-0.5" aria-hidden="true">💤</span>
          <div class="text-left">
            <p class="text-sm font-medium text-[var(--text-primary)]">This is on us, not you.</p>
            <p class="text-sm text-[var(--text-secondary)] mt-1 leading-relaxed">Try refreshing in a moment. If the problem persists, please check back later — we'll have our server back on its feet soon.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @keyframes sleepBreathe {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.06); }
  }
  .error-sleep-breathe {
    animation: sleepBreathe 3.5s ease-in-out infinite;
  }
  @keyframes zFloat1 {
    0% { opacity: 0; transform: translateY(0) translateX(0); }
    50% { opacity: 0.3; }
    100% { opacity: 0; transform: translateY(-16px) translateX(6px); }
  }
  @keyframes zFloat2 {
    0% { opacity: 0; transform: translateY(0) translateX(0); }
    50% { opacity: 0.4; }
    100% { opacity: 0; transform: translateY(-20px) translateX(10px); }
  }
  @keyframes zFloat3 {
    0% { opacity: 0; transform: translateY(0) translateX(0); }
    50% { opacity: 0.5; }
    100% { opacity: 0; transform: translateY(-24px) translateX(14px); }
  }
  .error-z-1 { animation: zFloat1 3s ease-out infinite; }
  .error-z-2 { animation: zFloat2 3s ease-out 0.4s infinite; }
  .error-z-3 { animation: zFloat3 3s ease-out 0.8s infinite; }
  @media (prefers-reduced-motion: reduce) {
    .error-sleep-breathe { animation: none; }
    .error-z-1, .error-z-2, .error-z-3 { animation: none; opacity: 0.2; }
  }
</style>
