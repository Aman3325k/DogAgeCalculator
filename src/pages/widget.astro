---
import '../styles/global.css';
import { BREED_SIZES } from '../scripts/breed-data.js';

const breedSizes = [
  { value: 'small', label: 'Small', desc: 'under 20 lbs' },
  { value: 'medium', label: 'Medium', desc: '20-50 lbs' },
  { value: 'large', label: 'Large', desc: '50-90 lbs' },
  { value: 'giant', label: 'Giant', desc: '90+ lbs' },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dog Age Calculator Widget</title>
    <meta name="robots" content="noindex, nofollow" />
    <script is:inline>
      (function() {
        const params = new URLSearchParams(window.location.search);
        // Theme
        const theme = params.get('theme');
        if (theme === 'light') {
          document.documentElement.classList.add('light');
        } else if (theme === 'dark') {
          document.documentElement.classList.remove('light');
        } else {
          // Fallback to system preference
          if (window.matchMedia('(prefers-color-scheme: light)').matches) {
            document.documentElement.classList.add('light');
          }
        }
        // Accent Color
        const accent = params.get('accent');
        if (accent) {
          const cleanHex = accent.startsWith('#') ? accent : '#' + accent;
          if (/^#[0-9A-F]{3,8}$/i.test(cleanHex)) {
            document.documentElement.style.setProperty('--btn-primary-bg', cleanHex);
            document.documentElement.style.setProperty('--gradient-from', cleanHex);
            document.documentElement.style.setProperty('--gradient-to', cleanHex);
          }
        }
      })();
    </script>
    <style>
      body {
        background: var(--bg-secondary);
        min-height: auto;
        padding: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .widget-card {
        width: 100%;
        max-width: 400px;
        margin: 0 auto;
      }
    </style>
  </head>
  <body>
    <div class="widget-card card p-5 relative overflow-hidden border-2 border-[var(--border-default)]">
      <div class="flex items-center gap-2 mb-4">
        <span class="text-2xl">🐶</span>
        <div>
          <h1 class="text-base font-display font-extrabold text-[var(--text-primary)] leading-tight">Dog Age Calculator</h1>
          <p class="text-[10px] text-[var(--text-muted)]">Find your dog's true biological age</p>
        </div>
      </div>

      <form id="widget-form" class="space-y-4">
        <div>
          <label class="block text-[11px] font-bold text-[var(--text-secondary)] mb-1">Breed Size</label>
          <select id="widget-size" class="select-base text-xs py-1.5" required>
            <option value="" disabled selected>Select size...</option>
            {breedSizes.map(bs => (
              <option value={bs.value}>{bs.label} ({bs.desc})</option>
            ))}
          </select>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label for="widget-years" class="block text-[11px] font-bold text-[var(--text-secondary)] mb-1">Age (Years)</label>
            <input type="number" id="widget-years" class="input-base text-xs py-1.5" min="0" max="40" placeholder="e.g. 3" required />
          </div>
          <div>
            <label for="widget-months" class="block text-[11px] font-bold text-[var(--text-secondary)] mb-1">Months</label>
            <select id="widget-months" class="select-base text-xs py-1.5">
              {Array.from({ length: 12 }, (_, i) => (
                <option value={i}>{i} mo</option>
              ))}
            </select>
          </div>
        </div>

        <button type="submit" class="btn-primary w-full justify-center text-xs py-2.5 px-4 font-bold btn-pulse mt-2">
          Calculate Human Age
        </button>
      </form>

      <div id="widget-result" class="hidden mt-4 pt-4 border-t border-[var(--border-default)] text-center space-y-2.5 fade-in-up">
        <div>
          <p class="text-[10px] text-[var(--text-muted)] font-bold">Equivalent Human Age</p>
          <p class="text-4xl font-display font-extrabold text-[var(--btn-primary-bg)] py-1" id="result-age">—</p>
          <span class="stage-pill text-[10px] py-0.5 px-2" id="result-stage">—</span>
        </div>
        
        <button type="button" id="widget-reset" class="text-[10px] text-[var(--text-faint)] hover:text-[var(--text-secondary)] underline bg-transparent border-0 cursor-pointer">
          ← Reset Calculator
        </button>
      </div>

      <div class="mt-4 pt-3 border-t border-[var(--border-default)] text-center">
        <a href="https://dogbreedage.com" target="_blank" rel="noopener" class="text-[9px] text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors no-underline font-semibold flex items-center justify-center gap-1">
          Powered by DogBreedAge.com 🐾
        </a>
      </div>
    </div>

    <script>
      import { BREED_SIZES, calcDogAge, getLifeStage } from '../scripts/breed-data.js';

      const form = document.getElementById('widget-form');
      const sizeSelect = document.getElementById('widget-size');
      const yearsInput = document.getElementById('widget-years');
      const monthsSelect = document.getElementById('widget-months');
      const resultDiv = document.getElementById('widget-result');
      const resultAge = document.getElementById('result-age');
      const resultStage = document.getElementById('result-stage');
      const resetBtn = document.getElementById('widget-reset');

      if (form) {
        form.addEventListener('submit', (e) => {
          e.preventDefault();
          const size = sizeSelect.value;
          const years = parseInt(yearsInput.value) || 0;
          const months = parseInt(monthsSelect.value) || 0;

          if (!size) {
            alert('Please select a breed size.');
            return;
          }
          if (years === 0 && months === 0) {
            alert('Please enter an age greater than 0.');
            return;
          }

          const multiplier = BREED_SIZES[size].multiplier;
          const humanAge = calcDogAge(years, months, multiplier);
          const totalYears = years + (months / 12);
          const stage = getLifeStage(totalYears, size);

          resultAge.textContent = `${humanAge} yrs`;
          resultStage.className = `stage-pill text-[10px] py-0.5 px-2 stage-${stage.replace(' ', '-')}`;
          resultStage.textContent = stage;

          form.classList.add('hidden');
          resultDiv.classList.remove('hidden');
        });
      }

      if (resetBtn) {
        resetBtn.addEventListener('click', () => {
          form.classList.remove('hidden');
          resultDiv.classList.add('hidden');
          form.reset();
        });
      }
    </script>
  </body>
</html>
