---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  noindex?: boolean;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
}

const { title, description, noindex, canonical, ogImage, ogType } = Astro.props;
const site = 'https://dogbreedage.com';
const ogImg = ogImage || `${site}/images/og-default.webp`;
const canon = canonical || `${site}${Astro.url.pathname}`;
const defaultOgType = Astro.url.pathname.includes('-age-calculator') ? 'article' : 'website';
const resolvedOgType = ogType || defaultOgType;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta name="robots" content={noindex ? 'noindex' : 'index, follow'} />
    <link rel="sitemap" href="/sitemap.xml" />
    <script>
      (function() {
        var t = localStorage.getItem('dogbreedage_theme');
        if (t === 'light') { document.documentElement.classList.add('light'); }
        else if (!t) {
          if (window.matchMedia('(prefers-color-scheme: light)').matches) {
            document.documentElement.classList.add('light');
          }
        }
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | DOGBREEDAGE</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canon} />
    <meta property="og:title" content={`${title} | DOGBREEDAGE`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canon} />
    <meta property="og:type" content={resolvedOgType} />
    <meta property="og:image" content={ogImg} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="DOGBREEDAGE" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | DOGBREEDAGE`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImg} />
    <meta name="twitter:image:width" content="1200" />
    <meta name="twitter:image:height" content="630" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" id="theme-color" content="#000000" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black" />
    {Astro.url.pathname === '/' && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebApplication",
        "name": "DOGBREEDAGE - Dog Age Calculator by Breed Size",
        "url": "https://dogbreedage.com",
        "description": "The most accurate dog age calculator using breed-size based scientific formula. Calculate your dog's human age by breed size.",
        "applicationCategory": "LifestyleApplication",
        "operatingSystem": "All",
        "browserRequirements": "Requires JavaScript",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        },
        "author": {
          "@type": "Organization",
          "name": "DOGBREEDAGE",
          "url": "https://dogbreedage.com"
        },
        "publisher": {
          "@type": "Organization",
          "name": "DOGBREEDAGE",
          "url": "https://dogbreedage.com"
        },
        "datePublished": "2025-01-15",
        "dateModified": new Date().toISOString().split('T')[0]
      })} />
    )}
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="skip-to-main">Skip to main content</a>
    <div id="page-progress" class="fixed top-0 left-0 right-0 z-[60] h-0.5 bg-transparent">
      <div id="page-progress-fill" class="h-full bg-[var(--text-primary)] transition-all duration-300" style="width: 0%"></div>
    </div>
    <Header />
    <main class="flex-1" id="main-content">
      <slot />
    </main>
    <Footer />
      <div id="pwa-banner" class="hidden fixed bottom-0 left-0 right-0 z-[55] bg-[var(--bg-secondary)] border-t border-[var(--border-default)] p-4 flex flex-wrap sm:flex-nowrap items-center justify-between gap-4" role="dialog" aria-modal="true" aria-label="Install app prompt">
      <div class="flex items-center gap-4">
        <span class="text-lg shrink-0">📱</span>
        <div>
          <span class="text-sm font-bold text-[var(--text-primary)] shrink-0 block">Add DogBreedAge to your phone</span>
          <p class="text-xs text-[var(--text-secondary)]">Calculate your dog's age instantly — no browser needed. Works offline too.</p>
        </div>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <button id="pwa-install" class="btn-primary text-xs py-2 px-4">Install</button>
        <button id="pwa-dismiss" class="text-[var(--text-faint)] hover:text-[var(--text-primary)] text-lg leading-none p-2" aria-label="Dismiss install prompt">&times;</button>
      </div>
    </div>
      <div id="cookie-banner" class="hidden fixed bottom-0 left-0 right-0 z-40 bg-[var(--bg-primary)] border-t border-[var(--border-default)] p-4 sm:p-4" role="dialog" aria-modal="true" aria-label="Cookie notice">
      <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-xs sm:text-sm text-[var(--text-secondary)]">We use cookies to remember your preferences (dark mode, weight unit). No tracking or analytics cookies are used.</p>
        <div class="flex items-center gap-2 shrink-0">
          <button id="cookie-accept" class="btn-primary text-xs py-2 px-4">Got it</button>
        </div>
      </div>
    </div>
    <button id="back-to-top" class="back-to-top no-print" aria-label="Back to top" tabindex="0">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true" focusable="false"><polyline points="18 15 12 9 6 15"/></svg>
    </button>
    <div id="toast-container" class="fixed bottom-4 right-4 z-50 flex flex-col gap-2 pointer-events-none"></div>
    <script>
      // Page scroll-progress bar
      (function() {
        const fill = document.getElementById('page-progress-fill');
        if (!fill) return;
        function updateProgress() {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          const pct = docHeight > 0 ? Math.min(100, (scrollTop / docHeight) * 100) : 0;
          fill.style.width = pct + '%';
        }
        window.addEventListener('load', () => {
          window.addEventListener('scroll', updateProgress, { passive: true });
          updateProgress();
        });
      })();
    </script>
  </body>
</html>
